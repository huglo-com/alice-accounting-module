# Ed25519 private key (PEM) or path to PEM file
MODULE_PRIVATE_KEY_PATH=./private.pem

# Huglo registration challenge (issued by Huglo UI during pending registration)
MODULE_CHALLENGE=

# Public base URL registered in Huglo (must match what you submitted in the UI)
MODULE_ENDPOINT=https://your-module.example.com

# Optional: Huglo directory URL (defaults to https://account.huglo.com)
# HUGLO_DIRECTORY_URL=https://account.huglo.com

# Server port (default 3200)
PORT=3200
